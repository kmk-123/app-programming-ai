rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── users ──────────────────────────────────────────────
    match /users/{userId} {
      // 친구 검색을 위해 인증된 사용자면 누구나 읽기 가능
      allow read: if request.auth != null;
      // 본인 프로필만 수정 가능
      allow write: if request.auth != null && request.auth.uid == userId;

      // friends 서브컬렉션: 수락 시 양쪽 모두 써야 하므로 당사자 둘 다 허용
      match /friends/{friendId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null
          && (request.auth.uid == userId || request.auth.uid == friendId);
      }
    }

    // ── schedules ──────────────────────────────────────────
    match /schedules/{scheduleId} {
      // 친구 가용 상태 조회를 위해 인증 사용자는 읽기 허용
      allow read: if request.auth != null;
      // 생성: userId 필드가 본인이어야 함
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
      // 수정·삭제: 소유자만
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    // ── friend_requests ────────────────────────────────────
    match /friend_requests/{requestId} {
      // 발신자·수신자만 조회 가능
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.fromUserId
            || request.auth.uid == resource.data.toUserId);
      // 발신자만 생성
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.fromUserId;
      // 수신자만 상태 변경(수락/거절)
      allow update: if request.auth != null
        && request.auth.uid == resource.data.toUserId;
    }

    // ── invites ────────────────────────────────────────────
    match /invites/{inviteId} {
      // 초대자·수신자만 조회
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.fromUserId
            || request.auth.uid in resource.data.toUserIds);
      // 초대자만 생성
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.fromUserId;
      // 초대자·수신자 모두 업데이트 가능(응답 저장, chatRoomId 설정)
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.fromUserId
            || request.auth.uid in resource.data.toUserIds);
    }

    // ── chat_rooms ─────────────────────────────────────────
    match /chat_rooms/{chatRoomId} {
      // 참여자만 읽기·업데이트 가능
      allow read, update: if request.auth != null
        && request.auth.uid in resource.data.participantIds;
      // 생성: 생성자가 participantIds에 포함되어야 함
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participantIds;

      // messages 서브컬렉션
      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in
            get(/databases/$(database)/documents/chat_rooms/$(chatRoomId)).data.participantIds;
        allow create: if request.auth != null
          && request.auth.uid in
            get(/databases/$(database)/documents/chat_rooms/$(chatRoomId)).data.participantIds
          && request.auth.uid == request.resource.data.senderId;
      }
    }
  }
}
